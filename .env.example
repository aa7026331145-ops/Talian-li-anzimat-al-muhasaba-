# ─────────────────────────────────────────────────────────────────
# Root .env  —  used by docker-compose.yml
# Copy this file:  cp .env.example .env
# Then edit the values below as needed.
# ─────────────────────────────────────────────────────────────────

# Application
APP_NAME="Talian ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=80

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database — DB_HOST is set automatically to "db" by docker-compose
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=talian_erp
DB_USERNAME=talian
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# Cache / Queue / Session
# For Docker deployment these default to "file" which needs no extra service.
# Set to "redis" if you want to use the Redis container.
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis (optional — used when CACHE_STORE/QUEUE_CONNECTION/SESSION_DRIVER = redis)
REDIS_HOST=redis
REDIS_PORT=6379

# Mail
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_FROM_ADDRESS="noreply@talian-erp.local"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,frontend

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost
